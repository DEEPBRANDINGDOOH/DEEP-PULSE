rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: Check if user is authenticated ──
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Helper: Check if auth UID matches wallet address ──
    function isOwner(walletAddress) {
      return isAuthenticated() && request.auth.uid == walletAddress;
    }

    // ── Helper: Check if user is admin ──
    function isAdmin() {
      return isAuthenticated() && request.auth.uid == '89Ez94pHfSNAUAPYrN7y3UmEfh4ggxr9biA4AS2nXVZc';
    }

    // ── Notifications ──
    // HACKATHON: Relaxed rules for devnet demo
    // TODO: Re-enable strict auth for mainnet
    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // ── Hubs ──
    // HACKATHON: Relaxed rules for devnet demo
    // TODO: Re-enable strict auth + validation for mainnet
    match /hubs/{hubId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── Subscriptions ──
    // HACKATHON: Relaxed rules for devnet demo
    // TODO: Re-enable strict auth for mainnet
    match /subscriptions/{subscriptionId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
      allow update: if false;
    }

    // ── FCM Tokens ──
    // Authenticated users can register their device token (doc ID must match auth UID)
    match /fcmTokens/{walletAddress} {
      allow read: if false;
      allow write: if isAuthenticated()
        && walletAddress == request.auth.uid
        && request.resource.data.keys().hasAll(['token', 'platform'])
        && request.resource.data.token is string
        && request.resource.data.token.size() > 0
        && request.resource.data.platform == 'android';
    }

    // ── Ad Creatives (pending review queue) ──
    // Readable by anyone; writes only via Cloud Functions (Admin SDK)
    match /adCreatives/{creativeId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Active Ads (rotation pool) ──
    match /activeAds/{adId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Analytics per user ──
    // Only the wallet owner (or admin) can read their own analytics
    // Server-only writes via trackEvent Cloud Function
    match /analytics/{walletAddress} {
      allow read: if isOwner(walletAddress) || isAdmin();
      allow write: if false;
      match /{subcollection=**} {
        allow read: if isOwner(walletAddress) || isAdmin();
        allow write: if false;
      }
    }

    // ── Global Stats ──
    match /globalStats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── User profiles / scores ──
    // Updated by dailyScoreUpdate Cloud Function
    match /users/{walletAddress} {
      allow read: if true;
      allow write: if false;
    }

    // ── Reports ──
    match /reports/{reportId} {
      allow read: if false;
      allow write: if false;
    }

    // ── Moderation Log ──
    match /moderationLog/{logId} {
      allow read: if false;
      allow write: if false;
    }

    // ── Boost Vaults ──
    // Only authenticated users can view vault data
    match /boostVaults/{vaultId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Talent Submissions ──
    // HACKATHON: Relaxed rules for devnet demo
    // TODO: Re-enable strict auth for mainnet
    match /talentSubmissions/{submissionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── DAO Proposals ──
    match /daoProposals/{proposalId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── Hub Feedbacks ──
    match /hubFeedbacks/{feedbackId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── Custom Deals (DOOH) ──
    match /customDeals/{dealId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── Admin Conversations ──
    match /adminConversations/{conversationId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── DOOH Campaigns ──
    match /doohCampaigns/{campaignId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── User Scores ──
    match /userScores/{walletAddress} {
      allow read: if true;
      allow write: if true;
    }

    // ── Deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
