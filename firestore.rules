rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Notifications ──
    // Readable by anyone; only Cloud Functions (admin SDK) write
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if false; // server-only via Cloud Functions
    }

    // ── Hubs ──
    match /hubs/{hubId} {
      allow read: if true;
      allow write: if false; // server-only
    }

    // ── Ad Creatives (pending review queue) ──
    match /adCreatives/{creativeId} {
      allow read: if true;
      allow write: if false; // server-only
    }

    // ── Active Ads (rotation pool) ──
    match /activeAds/{adId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Analytics per user ──
    match /analytics/{walletAddress} {
      allow read: if true;
      allow write: if false; // server-only via trackEvent
      match /{subcollection=**} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Global Stats ──
    match /globalStats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── User profiles / scores ──
    match /users/{walletAddress} {
      allow read: if true;
      allow write: if false; // updated by dailyScoreUpdate
    }

    // ── Reports ──
    match /reports/{reportId} {
      allow read: if false; // admin-only via Cloud Functions
      allow write: if false;
    }

    // ── Moderation Log ──
    match /moderationLog/{logId} {
      allow read: if false;
      allow write: if false;
    }

    // ── Boost Vaults ──
    match /boostVaults/{vaultId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
