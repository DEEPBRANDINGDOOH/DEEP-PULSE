rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Notifications ──
    // Readable by anyone; client creates must include required fields + valid data
    // Cloud Functions also write via Admin SDK (bypasses rules)
    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['hubId', 'title', 'body', 'walletAddress'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500
        && request.resource.data.hubId is string
        && request.resource.data.walletAddress is string
        && request.resource.data.walletAddress.size() >= 32;
      allow update, delete: if false;
    }

    // ── Hubs ──
    // Readable by anyone; client creates must have status PENDING (enforced)
    // Updates: subscriber count changes allowed for any client;
    // Admin status changes (suspend/reactivate/delete) routed through Cloud Functions (Admin SDK)
    // Client-side status updates restricted to valid transitions with value validation
    match /hubs/{hubId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'status', 'creator'])
        && request.resource.data.status == 'PENDING'
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 64
        && request.resource.data.creator is string
        && request.resource.data.creator.size() >= 32;
      allow update: if (
        // Case 1: Subscriber count change only (any authenticated client)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['subscribers'])
        && request.resource.data.subscribers is int
        && request.resource.data.subscribers >= 0
      ) || (
        // Case 2: Hub approval/rejection (admin operations via client — status value validated)
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'active', 'approvedAt', 'approvedBy', 'rejectedAt', 'rejectedBy',
                    'suspendedAt', 'suspendedBy', 'reactivatedAt', 'reactivatedBy',
                    'subscriptionExpiresAt'])
        && request.resource.data.status in ['ACTIVE', 'REJECTED', 'SUSPENDED', 'OVERDUE', 'DELETED']
      );
      // Deletion only via Cloud Functions (Admin SDK bypasses rules)
      allow delete: if false;
    }

    // ── Subscriptions ──
    // Client writes for subscribe/unsubscribe (FCM topic sync)
    // Document ID format: {walletAddress}_{hubId}
    // Create must include valid wallet + hubId, ID must match wallet prefix
    match /subscriptions/{subscriptionId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['walletAddress', 'hubId'])
        && request.resource.data.walletAddress is string
        && request.resource.data.walletAddress.size() >= 32
        && request.resource.data.hubId is string
        && subscriptionId.matches(request.resource.data.walletAddress + '_.*');
      allow delete: if true;
      allow update: if false;
    }

    // ── FCM Tokens ──
    // Client writes for device token registration
    // Document ID is the wallet address; prevents overwriting other users' tokens
    match /fcmTokens/{walletAddress} {
      allow read: if false;
      allow write: if request.resource.data.keys().hasAll(['token', 'platform'])
        && request.resource.data.token is string
        && request.resource.data.token.size() > 0
        && request.resource.data.platform == 'android'
        && walletAddress.size() >= 32;
    }

    // ── Ad Creatives (pending review queue) ──
    // Readable by anyone; writes only via Cloud Functions (Admin SDK)
    match /adCreatives/{creativeId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Active Ads (rotation pool) ──
    match /activeAds/{adId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Analytics per user ──
    // Server-only writes via trackEvent Cloud Function
    match /analytics/{walletAddress} {
      allow read: if true;
      allow write: if false;
      match /{subcollection=**} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Global Stats ──
    match /globalStats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── User profiles / scores ──
    // Updated by dailyScoreUpdate Cloud Function
    match /users/{walletAddress} {
      allow read: if true;
      allow write: if false;
    }

    // ── Reports ──
    match /reports/{reportId} {
      allow read: if false;
      allow write: if false;
    }

    // ── Moderation Log ──
    match /moderationLog/{logId} {
      allow read: if false;
      allow write: if false;
    }

    // ── Boost Vaults ──
    match /boostVaults/{vaultId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
