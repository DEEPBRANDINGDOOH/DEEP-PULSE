{
  "name": "deep-pulse",
  "version": "2.0.0",
  "description": "Web3 Notification Hub for Solana Mobile - Hackathon Ready",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "expo start",
    "test": "jest",
    "lint": "eslint .",
    "postinstall": "node scripts/patch-nativewind.js",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "anchor:deploy:devnet": "anchor deploy --provider.cluster devnet",
    "anchor:idl": "anchor idl init --filepath target/idl/deep_pulse.json",
    "devnet:deploy": "chmod +x scripts/deploy-devnet.sh && ./scripts/deploy-devnet.sh",
    "devnet:init": "yarn run ts-mocha -p ./tsconfig.json -t 120000 scripts/init-devnet.ts --provider.cluster devnet --skip-local-validator",
    "local:init": "yarn run ts-mocha -p ./tsconfig.json -t 120000 scripts/init-devnet.ts",
    "devnet:deploy-and-init": "npm run devnet:deploy && npm run devnet:init"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/firestore": "^23.8.6",
    "@react-native-firebase/functions": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-native-firebase/storage": "^23.8.6",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@solana-mobile/mobile-wallet-adapter-protocol": "^2.1.0",
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.1.0",
    "@solana-mobile/mobile-wallet-adapter-walletlib": "^1.4.0",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.87.6",
    "@types/react": "~18.3.12",
    "axios": "^1.6.0",
    "buffer": "^6.0.3",
    "date-fns": "^3.0.0",
    "deasync": "^0.1.31",
    "expo": "^52.0.49",
    "expo-device": "~7.0.3",
    "js-sha256": "^0.11.1",
    "nativewind": "^2.0.11",
    "postcss": "8.4.31",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-get-random-values": "^1.11.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-web": "~0.19.10",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/runtime": "^7.23.5",
    "@react-native-community/cli": "^20.0.1",
    "@react-native-community/cli-platform-android": "^13.6.9",
    "@react-native/babel-preset": "0.76.9",
    "@react-native/eslint-config": "0.76.9",
    "@react-native/metro-config": "0.76.9",
    "@react-native/typescript-config": "0.76.9",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "jest": "^29.7.0",
    "mocha": "^11.7.5",
    "tailwindcss": "3.2.7",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "8.4.31"
  },
  "engines": {
    "node": ">=18"
  },
  "private": true
}
