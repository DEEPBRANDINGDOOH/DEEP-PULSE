rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Ad Creatives — uploaded by brands
    // Path: ad-creatives/{walletAddress}/{filename}
    match /ad-creatives/{walletAddress}/{fileName} {
      // Anyone can read (ads are public content)
      allow read: if true;

      // Only the wallet owner can upload to their own folder
      // Max file size: 5 MB (covers lockscreen 5MB and banner 2MB)
      allow write: if request.auth != null
                   && request.auth.uid == walletAddress
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Only the uploader (wallet owner) can delete their own files
      allow delete: if request.auth != null
                    && request.auth.uid == walletAddress;
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
