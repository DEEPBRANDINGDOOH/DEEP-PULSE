rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Ad Creatives — uploaded by brands
    // Path: ad-creatives/{walletAddress}/{filename}
    match /ad-creatives/{walletAddress}/{fileName} {
      // Anyone can read (ads are public content)
      allow read: if true;

      // HACKATHON: Allow uploads with basic validation (auth relaxed for devnet demo)
      // TODO: Re-enable strict auth for mainnet: request.auth.uid == walletAddress
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Allow delete during hackathon
      allow delete: if true;
    }

    // Hub Logos — uploaded by hub creators
    // Path: hub-logos/{walletAddress}/{filename}
    match /hub-logos/{walletAddress}/{fileName} {
      // Anyone can read (logos are public)
      allow read: if true;

      // HACKATHON: Allow uploads with basic validation
      // TODO: Re-enable strict auth for mainnet
      allow write: if request.resource.size < 1 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      allow delete: if true;
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
