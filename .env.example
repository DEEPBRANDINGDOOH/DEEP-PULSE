# ============================================
# DEEP Pulse — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore)
# ============================================

# ----------------------------------------
# SOLANA NETWORK
# ----------------------------------------
# Options: devnet | mainnet-beta | testnet
SOLANA_NETWORK=devnet

# RPC Endpoints (use your own for production)
RPC_ENDPOINT_DEV=https://api.devnet.solana.com
RPC_ENDPOINT_PROD=https://api.mainnet-beta.solana.com

# ----------------------------------------
# PROGRAM & TOKEN
# ----------------------------------------
# Anchor Program ID — replace after `anchor deploy`
PROGRAM_ID=3N5coxatEEbdLuTKovXdzrJX9E7ZAD6t2bWuz7BgGR63

# $SKR Token Mint (existing SPL token on Solana)
SKR_MINT=SKRbvo6Gf7GondiT3BbTfuRDPqLWei4j2Qy2NPGZhW3
SKR_DECIMALS=6

# ----------------------------------------
# ADMIN
# ----------------------------------------
# Platform admin wallet (Solana public key)
ADMIN_WALLET=YOUR_WALLET_HERE

# Optional: additional admin wallets (comma-separated)
# ADMIN_WALLETS=WALLET1,WALLET2

# ----------------------------------------
# APP IDENTITY (Mobile Wallet Adapter)
# ----------------------------------------
APP_NAME=Deep Pulse
APP_URI=https://deeppulse.app
APP_ICON=favicon.ico

# ----------------------------------------
# API (optional — for off-chain services)
# ----------------------------------------
API_BASE_URL_DEV=http://localhost:3000/api
API_BASE_URL_PROD=https://api.deeppulse.app/api

# ----------------------------------------
# ANCHOR (for smart contract development)
# ----------------------------------------
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
